# brain.merrules — the gbrain corpus rulebook.
#
# Three families of declarative rule extend Meridian's deterministic English
# surface so a gbrain SKILL.md compiles with minimal edits:
#
#   === desugar ===      surface idioms  → canonical Meridian statements
#   === sections ===     markdown heading aliases → closed section roles
#   === conventions ===  Inform-style cross-cutting behaviour (back-links,
#                        notability gate, brain-first) declared ONCE
#
# Every rule is a compile-time equivalence: its output re-parses + lowers
# through the same strict pipeline, so a rule can never reach the LLM, widen
# tool scope, or bypass strict mode.

=== desugar ===

# `If X -> Y` / `If X then Y` arrow conditionals (single-line action).
rule "arrow-conditional":
  match: If {condition} -> {action}
  rewrite: {action} only when {condition}.

rule "arrow-conditional-then":
  match: If {condition} then {action}
  rewrite: {action} only when {condition}.

# `Report:`/`Output:` lines become a deterministic skill.report emit.
rule "report-emit":
  match: Report: {message}
  lowers to: emit skill.report with message = {message}.

rule "output-emit":
  match: Output: {message}
  lowers to: emit skill.report with message = {message}.

# Annotated command (1A): `Run `cmd` to <purpose>` normalizes to the canonical
# backticked-command-with-annotation form. The engine's parseBlock hoist then
# routes the rewritten ``cmd`` to the deterministic shell.run path, carrying
# <purpose> as a source comment. Anchored on the backticks (literal "Run `" …
# "` to ") so it only fires on a genuine backticked command, never on prose
# "Run the …" lines or a command that merely contains the substring "to".
rule "annotated-command":
  match: Run `{command}` to {purpose}
  rewrite: `{command}` -- {purpose}.

# Markdown checklists (`- [ ] item`, `□ item`) are verification asserts.
rule "checklist-open":
  match: [ ] {item}
  rewrite: make sure {item}.

rule "checklist-done":
  match: [x] {item}
  rewrite: make sure {item}.

rule "checklist-box":
  match: □ {item}
  rewrite: make sure {item}.

=== sections ===

section "Contract", "Guarantees", "Contract & Guarantees", "Invariants" -> invariants
section "Phases", "Workflow", "Pipeline", "Protocol", "Steps", "Process", "Procedure" -> procedure
section "When To Use", "Use When", "Primary Triggers", "When This Applies" -> applicability
section "When NOT To Use", "When Not To Use", "Do NOT Use", "Skip When", "Do Not Use" -> negative-applicability
section "Anti-Patterns", "Anti Patterns", "Avoid", "Pitfalls" -> prohibitions
section "Output Format", "Output", "Report Format", "Result Format" -> template
section "Prerequisites", "Preconditions" -> applicability
section "Quality Rules", "Hard Rules", "Verification Checklist", "Quality Gate" -> invariants

# Iron-law back-linking / cross-reference enforcement sections (executable).
# Aliasing the descriptive headings to `procedure` lets the skills name the
# section naturally and drop the redundant `(( role: procedure ))` marker.
section "Enforce Back-Links", "Repair Missing Back-Links", "Create Missing Cross-References" -> procedure

# Recurring "<X> guard" precondition sections across the corpus (executable).
section "Freshness Guard", "Stale-Page Guard", "Coverage Guard", "Escalation Guard", "Pre-Publish Guard" -> procedure

# Health-audit scans + structured-graph backfill (executable).
section "Page-Health Scan", "Graph Extraction" -> procedure

# Acceptance / verification sections — fuzzy criteria routed to the planner via
# a `!!! checklist (( ai-autonomy ))` marker (loop until every criterion holds).
section "Confirm", "Acceptance", "Acceptance Criteria", "Definition Of Done", "Exit Criteria", "Verification" -> procedure

# Operational protocol headings that recur across setup/import/schema skills.
section "Resume Protocol", "Post-Import", "Post Import", "Health Check", "Full Verification", "Lookup Sequence", "Sync-After-Write Rule" -> procedure

=== conventions ===

# Iron-Law back-linking: any page that mentions an entity gets a reciprocal link.
after writing a page that mentions an entity:
  create a back-link from the entity to the page.

# Notability gate before creating entity pages.
before writing a page about an entity:
  make sure the entity is notable.

# Brain-first: consult the local knowledge graph before any external call.
before calling an external service:
  check the brain first.
